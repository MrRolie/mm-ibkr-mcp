# =============================================================================
# mm-ibkr-mcp environment
# =============================================================================
# This repo assumes IB Gateway or TWS is already running on the user's machine.
# The MCP server focuses on connecting, monitoring, previewing, and trading.
#
# Runtime config.json and control.json still live under MM_IBKR_DATA_DIR by default.
# Override specific paths with MM_IBKR_CONFIG_PATH or MM_IBKR_CONTROL_DIR when needed.
# =============================================================================

# Optional base data directory for config.json, control.json, logs, and SQLite state
# MM_IBKR_DATA_DIR=

# Optional explicit config.json path
# MM_IBKR_CONFIG_PATH=

# Optional explicit control.json directory
# MM_IBKR_CONTROL_DIR=

# =============================================================================
# Interactive Brokers connection
# =============================================================================

# IB Gateway / TWS host
# IBKR_HOST=127.0.0.1

# IB Gateway / TWS port
# Common defaults: 4002 for paper, 4001 for live, but this repo does not infer mode.
# IBKR_PORT=4002

# Client ID used by the MCP server connection
# IBKR_CLIENT_ID=1

# Optional default account id used when tools omit account_id
# IBKR_ACCOUNT_ID=

# =============================================================================
# MCP server
# =============================================================================

# MCP transport: stdio | sse | streamable-http
# MCP_TRANSPORT=stdio

# MCP_HOST=127.0.0.1
# MCP_PORT=8001

# Required for HTTP transports
# MCP_AUTH_TOKEN=

# Optional HTTP transport settings
# MCP_PUBLIC_BASE_URL=http://127.0.0.1:8001
# MCP_STREAMABLE_HTTP_PATH=/mcp
# MCP_SSE_PATH=/sse
# MCP_MESSAGE_PATH=/messages/

# Optional admin toggle
# MCP_ENABLE_ADMIN_TOOLS=false

# =============================================================================
# Order approval mode
# =============================================================================

# telegram: require Telegram approval before single-order and basket submission
# yolo: no approval gate; submission proceeds immediately
# Safe default is telegram.
# MCP_ORDER_APPROVAL_MODE=telegram

# =============================================================================
# Telegram human-in-the-loop
# =============================================================================

# Required when MCP_ORDER_APPROVAL_MODE=telegram
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Approval timeout for single orders and trade intents
# TELEGRAM_APPROVAL_TIMEOUT_SECONDS=300

# Approval timeout for execution unlock / control-change requests
# TELEGRAM_LIVE_UNLOCK_TIMEOUT_SECONDS=120

# =============================================================================
# Agent trading profiles
# =============================================================================

# Directory containing agent profile JSON files (default: data/profiles/)
# MCP_AGENT_PROFILE_DIR=

# Default profile ID loaded by ibkr_get_agent_profile
# MCP_AGENT_PROFILE_ID=default
