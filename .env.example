# =============================================================================
# mm-ibkr-gateway Secrets (.env)
# =============================================================================
# Linux default data dir in this workspace:
#   /home/mm-mike/trading_system/data/ib-gateway
#
# Operational settings live in config.json under that base dir by default.
# Trading controls live in control.json under that base dir by default.
# Override the base dir with MM_IBKR_DATA_DIR if needed, or override
# config.json directly with MM_IBKR_CONFIG_PATH.
# =============================================================================

# API authentication key (generate with generate-api-key.ps1)
# API_KEY=

# Admin token for /admin/* endpoints (required for admin operations)
# ADMIN_TOKEN=

# Optional: override base data directory
# MM_IBKR_DATA_DIR=

# Optional: override config.json path
# MM_IBKR_CONFIG_PATH=

# Optional: override control.json directory
# MM_IBKR_CONTROL_DIR=

# =============================================================================
# Telegram Human-in-the-Loop (optional — disables Telegram features if absent)
# =============================================================================

# Telegram bot token from @BotFather
# TELEGRAM_BOT_TOKEN=

# Target chat ID (your personal ID or a group/channel ID)
# Get your ID by messaging @userinfobot
# TELEGRAM_CHAT_ID=

# How long (seconds) a trade approval request waits before expiring (default: 300)
# TELEGRAM_APPROVAL_TIMEOUT_SECONDS=300

# How long (seconds) a live-trading-unlock request waits (default: 120)
# TELEGRAM_LIVE_UNLOCK_TIMEOUT_SECONDS=120

# =============================================================================
# MCP Trade Approval Enforcement
# =============================================================================

# Set to true to require ibkr_request_trade_approval before ibkr_place_order
# when live trading is active. Defaults to false (advisory only).
# MCP_ENFORCE_TRADE_APPROVAL=false

# =============================================================================
# Agent Trading Profiles
# =============================================================================

# Directory containing agent profile JSON files (default: data/profiles/)
# MCP_AGENT_PROFILE_DIR=

# Default profile ID loaded by ibkr_get_agent_profile (default: default)
# MCP_AGENT_PROFILE_ID=default
