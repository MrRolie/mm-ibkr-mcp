# =============================================================================
# mm-ibkr-gateway Secrets (.env)
# =============================================================================
# Linux default data dir in this workspace:
#   /home/mm-mike/trading_system/data/ib-gateway
#
# Operational settings live in config.json under that base dir by default.
# Trading controls live in control.json under that base dir by default.
# Override the base dir with MM_IBKR_DATA_DIR if needed, or override
# config.json directly with MM_IBKR_CONFIG_PATH.
# =============================================================================

# API authentication key (generate with generate-api-key.ps1)
# API_KEY=

# Admin token for /admin/* endpoints (required for admin operations)
# ADMIN_TOKEN=

# Optional: override base data directory
# MM_IBKR_DATA_DIR=

# Optional: override config.json path
# MM_IBKR_CONFIG_PATH=

# Optional: override control.json directory
# MM_IBKR_CONTROL_DIR=
