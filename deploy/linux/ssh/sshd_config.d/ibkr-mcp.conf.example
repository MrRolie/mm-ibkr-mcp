# Example Match block for a dedicated mm-ibkr-gateway SSH stdio account.
# Install under /etc/ssh/sshd_config.d/ after replacing placeholders.

Match User ibkr-mcp
    AuthenticationMethods publickey
    PasswordAuthentication no
    PermitTTY no
    AllowAgentForwarding no
    AllowTcpForwarding no
    X11Forwarding no
    PermitUserRC no
    ForceCommand /path/to/mm-ibkr-gateway/deploy/linux/scripts/run_mcp_stdio.sh
